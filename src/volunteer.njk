<!-- ══════════════════════════════ FORM ══════════════════ -->
<!--
  FORM SUBMISSION SETUP (Formspree — free, no backend needed):
  ────────────────────────────────────────────────────────────
  1. Go to https://formspree.io and create a free account
  2. Create a new form → copy your endpoint (looks like https://formspree.io/f/abcdefgh)
  3. Replace action="#volunteer-form-target" below with your Formspree endpoint
  4. Set method="POST" and remove the JS submit handler if using Formspree directly
  ────────────────────────────────────────────────────────────
-->
<section class="bridge-apply-section" id="volunteer-form" aria-labelledby="vol-form-heading">
  <div class="container bridge-apply-inner">
    <div class="bridge-apply-intro">
      <div class="section-label" style="justify-content:center;">Application</div>
      <h2 class="section-heading" id="vol-form-heading">Volunteer Application Form</h2>
      <p style="font-size:0.85rem;color:var(--muted);margin-top:10px;line-height:1.75;">
        The Uprising Of The Children Of God — fill in your details below and our team will be in touch.
      </p>
    </div>

    <form id="volunteer-application-form" novalidate aria-label="Volunteer application form">

      <!-- ── Personal Information ───────────────────────── -->
      <div class="bridge-form-block">
        <div class="bridge-form-block-header">
          <div class="bridge-form-block-title">Personal Information</div>
        </div>
        <div class="bridge-form-block-body">
          <div class="bridge-form-row">
            <div class="bridge-form-group">
              <label for="vol-name">Full Name <span class="req">*</span></label>
              <input type="text" id="vol-name" name="name" placeholder="Your full name" required autocomplete="name" />
            </div>
            <div class="bridge-form-group">
              <label for="vol-email">Email Address <span class="req">*</span></label>
              <input type="email" id="vol-email" name="email" placeholder="you@example.com" required autocomplete="email" />
            </div>
          </div>
          <div class="bridge-form-row">
            <div class="bridge-form-group">
              <label for="vol-phone">Phone <span class="req">*</span></label>
              <input type="tel" id="vol-phone" name="phone" placeholder="+1 (613) 000-0000" required autocomplete="tel" />
            </div>
            <div class="bridge-form-group">
              <label for="vol-address">Address <span class="req">*</span></label>
              <input type="text" id="vol-address" name="address" placeholder="Street, City" required autocomplete="street-address" />
            </div>
          </div>
          <div class="bridge-form-row">
            <div class="bridge-form-group">
              <label for="vol-country">Country <span class="req">*</span></label>
              <select id="vol-country" name="country" required>
                <option value="">Select a country…</option>
                <option>Canada</option>
                <option>Nigeria</option>
                <option>United States</option>
                <option>United Kingdom</option>
                <option>Botswana</option>
                <option>Ghana</option>
                <option>Kenya</option>
                <option>South Africa</option>
                <option>Other</option>
              </select>
            </div>
            <div class="bridge-form-group">
              <label for="vol-marital">Marital Status <span class="req">*</span></label>
              <select id="vol-marital" name="marital_status" required>
                <option value="">Select status…</option>
                <option>Single</option>
                <option>Married</option>
                <option>Divorced</option>
                <option>Widowed</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Areas of Interest ──────────────────────────── -->
      <div class="bridge-form-block">
        <div class="bridge-form-block-header">
          <div class="bridge-form-block-title">Areas of Service</div>
          <div class="bridge-form-block-sub">Select all areas you're interested in serving in.</div>
        </div>
        <div class="bridge-form-block-body">
          <div class="bridge-form-group">
            <label>Please select the area(s) you're interested in serving in: <span class="req">*</span></label>
            <div class="bridge-checkbox-grid" role="group" aria-label="Service areas">
              <label class="bridge-checkbox-item"><input type="checkbox" name="service_areas" value="Outreach and Evangelism" /> Outreach &amp; Evangelism</label>
              <label class="bridge-checkbox-item"><input type="checkbox" name="service_areas" value="Worship and Music" /> Worship &amp; Music</label>
              <label class="bridge-checkbox-item"><input type="checkbox" name="service_areas" value="Prayer and Intercession" /> Prayer &amp; Intercession</label>
              <label class="bridge-checkbox-item"><input type="checkbox" name="service_areas" value="Administration and Support" /> Administration &amp; Support</label>
              <label class="bridge-checkbox-item"><input type="checkbox" name="service_areas" value="Media and Communications" /> Media &amp; Communications</label>
              <label class="bridge-checkbox-item"><input type="checkbox" name="service_areas" value="Other" id="vol-other-check" /> Other (kindly specify)</label>
            </div>
          </div>
          <div class="bridge-form-group" id="vol-other-group" style="display:none;">
            <label for="vol-other-specify">Please specify other area(s)</label>
            <textarea id="vol-other-specify" name="other_areas" placeholder="Kindly specify other areas…"></textarea>
          </div>
          <div class="bridge-form-group">
            <label for="vol-skills">Relevant skills or experience <span class="req">*</span></label>
            <textarea id="vol-skills" name="skills" placeholder="Please list any relevant skills or experience…" required></textarea>
          </div>
          <div class="bridge-form-row">
            <div class="bridge-form-group">
              <label for="vol-hours">Hours per week you can commit <span class="req">*</span></label>
              <input type="text" id="vol-hours" name="hours_per_week" placeholder="e.g. 5–10 hours" required />
            </div>
            <div class="bridge-form-group">
              <label>Available to serve on weekends? <span class="req">*</span></label>
              <div class="bridge-radio-inline" role="radiogroup" aria-label="Weekend availability">
                <label class="bridge-checkbox-item"><input type="radio" name="weekends" value="Yes" required /> Yes</label>
                <label class="bridge-checkbox-item"><input type="radio" name="weekends" value="No" /> No</label>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Faith Background ───────────────────────────── -->
      <div class="bridge-form-block">
        <div class="bridge-form-block-header">
          <div class="bridge-form-block-title">Faith Background</div>
        </div>
        <div class="bridge-form-block-body">
          <div class="bridge-form-row">
            <div class="bridge-form-group">
              <label for="vol-christian-years">How long have you been a Christian? <span class="req">*</span></label>
              <input type="text" id="vol-christian-years" name="christian_duration" placeholder="e.g. 10 years" required />
            </div>
            <div class="bridge-form-group">
              <label for="vol-church">Current church affiliation <span class="req">*</span></label>
              <input type="text" id="vol-church" name="church_affiliation" placeholder="Name of your church" required />
            </div>
          </div>
        </div>
      </div>

      <!-- ── References ─────────────────────────────────── -->
      <div class="bridge-form-block">
        <div class="bridge-form-block-header">
          <div class="bridge-form-block-title">Personal References</div>
          <div class="bridge-form-block-sub">Please provide two personal references.</div>
        </div>
        <div class="bridge-form-block-body">
          <p style="font-size:0.8rem;font-weight:600;color:var(--navy);margin-bottom:16px;">Reference 1</p>
          <div class="bridge-form-row">
            <div class="bridge-form-group">
              <label for="vol-ref1-name">Name <span class="req">*</span></label>
              <input type="text" id="vol-ref1-name" name="ref1_name" placeholder="Full name" required />
            </div>
            <div class="bridge-form-group">
              <label for="vol-ref1-phone">Phone <span class="req">*</span></label>
              <input type="tel" id="vol-ref1-phone" name="ref1_phone" placeholder="+1 (613) 000-0000" required />
            </div>
          </div>
          <div class="bridge-form-row">
            <div class="bridge-form-group">
              <label for="vol-ref1-email">Email <span class="req">*</span></label>
              <input type="email" id="vol-ref1-email" name="ref1_email" placeholder="reference@example.com" required />
            </div>
            <div class="bridge-form-group">
              <label for="vol-ref1-rel">Relationship <span class="req">*</span></label>
              <input type="text" id="vol-ref1-rel" name="ref1_relationship" placeholder="e.g. Pastor, Colleague" required />
            </div>
          </div>

          <hr style="border:none;border-top:1px solid var(--border);margin:24px 0;" />

          <p style="font-size:0.8rem;font-weight:600;color:var(--navy);margin-bottom:16px;">Reference 2</p>
          <div class="bridge-form-row">
            <div class="bridge-form-group">
              <label for="vol-ref2-name">Name <span class="req">*</span></label>
              <input type="text" id="vol-ref2-name" name="ref2_name" placeholder="Full name" required />
            </div>
            <div class="bridge-form-group">
              <label for="vol-ref2-phone">Phone <span class="req">*</span></label>
              <input type="tel" id="vol-ref2-phone" name="ref2_phone" placeholder="+1 (613) 000-0000" required />
            </div>
          </div>
          <div class="bridge-form-row">
            <div class="bridge-form-group">
              <label for="vol-ref2-email">Email <span class="req">*</span></label>
              <input type="email" id="vol-ref2-email" name="ref2_email" placeholder="reference@example.com" required />
            </div>
            <div class="bridge-form-group">
              <label for="vol-ref2-rel">Relationship <span class="req">*</span></label>
              <input type="text" id="vol-ref2-rel" name="ref2_relationship" placeholder="e.g. Friend, Elder" required />
            </div>
          </div>
        </div>
      </div>

      <!-- ── Anything Else ──────────────────────────────── -->
      <div class="bridge-form-block">
        <div class="bridge-form-block-header">
          <div class="bridge-form-block-title">Anything Else?</div>
        </div>
        <div class="bridge-form-block-body">
          <div class="bridge-form-group">
            <label for="vol-more">Tell us more things about you that you'd like us to know</label>
            <textarea id="vol-more" name="additional_info" placeholder="Kindly tell us more things about you, that you'll like us to know…"></textarea>
          </div>
        </div>
      </div>

      <div class="bridge-form-submit-wrap">
        <button type="submit" class="form-submit" style="max-width:360px;margin:0 auto;display:block;font-size:1rem;padding:16px 32px;">
          Submit Application →
        </button>
        <p style="margin-top:14px;font-size:0.75rem;color:var(--muted);text-align:center;">Our team will review your application and reach out within 2–3 business days.</p>
      </div>
    </form>

    <!-- Success message -->
    <div class="bridge-success-message" id="vol-success" role="alert" aria-live="polite">
      <div class="bridge-success-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" width="26" height="26">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
      </div>
      <h3 style="font-family:var(--serif);font-size:1.5rem;color:var(--navy);margin-bottom:10px;">Application Received</h3>
      <p style="font-size:0.9rem;color:var(--muted);line-height:1.75;max-width:480px;margin:0 auto;">Thank you for your heart to serve! Your volunteer application has been submitted. Our team will review it and be in touch within 2–3 business days.</p>
      <p style="margin-top:20px;font-size:0.82rem;color:var(--gold);font-style:italic;">Welcome to the movement — Hayah International Ministries</p>
    </div>
  </div>
</section>

<script>
(function () {
  // ── Show/hide "Other areas" textarea ─────────────────────
  var otherCheck = document.getElementById('vol-other-check');
  var otherGroup = document.getElementById('vol-other-group');
  if (otherCheck && otherGroup) {
    otherCheck.addEventListener('change', function () {
      otherGroup.style.display = this.checked ? 'flex' : 'none';
    });
  }

  // ── Form submission ───────────────────────────────────────
  // Using Formspree: replace the endpoint below with your own.
  // Sign up free at https://formspree.io — create a form, copy the endpoint URL.
  var FORMSPREE_ENDPOINT = 'https://formspree.io/f/YOUR_FORM_ID';

  var form       = document.getElementById('volunteer-application-form');
  var successMsg = document.getElementById('vol-success');

  if (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var btn = form.querySelector('[type="submit"]');
      btn.disabled    = true;
      btn.textContent = 'Submitting…';

      var data = new FormData(form);

      fetch(FORMSPREE_ENDPOINT, {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' }
      }).then(function (res) {
        if (res.ok) {
          form.style.display      = 'none';
          successMsg.style.display = 'block';
          successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          throw new Error('Server error');
        }
      }).catch(function () {
        btn.disabled    = false;
        btn.textContent = 'Submit Application →';
        alert('There was an issue submitting your application. Please check your connection and try again, or email us directly at mailus@hayahministries.org');
      });
    });
  }
})();
</script>
