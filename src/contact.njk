---
layout: base.njk
title: Contact
description: Get in touch with Hayah International Ministries — Ottawa, Canada and Makurdi, Nigeria.
---

<div class="page-header">
  <div class="container page-header-inner">
    <div class="page-header-eyebrow">Get in Touch</div>
    <h1 class="page-header-title">We'd Love to <em>Hear From You</em></h1>
    <p class="page-header-sub">Whether you want to volunteer, partner, attend an event, or simply connect — we're here.</p>
  </div>
</div>

<section class="contact-section" id="contact" aria-labelledby="contact-heading">
  <div class="container">
    <h2 class="sr-only" id="contact-heading">Contact Hayah Ministries</h2>
    <div class="contact-grid">
      <div class="contact-info fade-up">
        <h3>Get in Touch</h3>
        <p>Reach us by phone, email, or through the contact form. Our team in Ottawa and Nigeria will respond within 2 business days.</p>
        <div class="contact-items" role="list" aria-label="Contact information">
          <div class="contact-item" role="listitem">
            <div class="contact-item-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16">
                <path d="M2 5.5A2.5 2.5 0 0 1 4.5 3h11A2.5 2.5 0 0 1 18 5.5v9a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 2 14.5v-9Z"/>
                <path d="m2 6 8 5 8-5"/>
              </svg>
            </div>
            <div class="contact-item-text">
              <div class="contact-item-label">Email</div>
              <div class="contact-item-value">mailus@hayahministries.org</div>
            </div>
          </div>
          <div class="contact-item" role="listitem">
            <div class="contact-item-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16">
                <path d="M2 6.5C2 5.672 2.672 5 3.5 5h2.062a1 1 0 0 1 .96.726l.95 3.325a1 1 0 0 1-.27 1.003l-1.062.968a10.04 10.04 0 0 0 4.838 4.838l.968-1.063a1 1 0 0 1 1.003-.269l3.325.95A1 1 0 0 1 17 16.438V18.5A1.5 1.5 0 0 1 15.5 20C8.044 20 2 13.956 2 6.5Z"/>
              </svg>
            </div>
            <div class="contact-item-text">
              <div class="contact-item-label">Canada</div>
              <div class="contact-item-value">+1 (613) 790-2794 · +1 (613) 252-3810</div>
            </div>
          </div>
          <div class="contact-item" role="listitem">
            <div class="contact-item-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16">
                <path d="M2 6.5C2 5.672 2.672 5 3.5 5h2.062a1 1 0 0 1 .96.726l.95 3.325a1 1 0 0 1-.27 1.003l-1.062.968a10.04 10.04 0 0 0 4.838 4.838l.968-1.063a1 1 0 0 1 1.003-.269l3.325.95A1 1 0 0 1 17 16.438V18.5A1.5 1.5 0 0 1 15.5 20C8.044 20 2 13.956 2 6.5Z"/>
              </svg>
            </div>
            <div class="contact-item-text">
              <div class="contact-item-label">Nigeria</div>
              <div class="contact-item-value">+234 (0) 703 702 7576</div>
            </div>
          </div>
        </div>
        <div style="margin-top:36px;background:var(--navy);border-radius:12px;padding:24px;">
          <div style="font-family:var(--serif);font-size:1.1rem;font-weight:600;color:var(--white);margin-bottom:8px;">Become a Volunteer</div>
          <p style="font-size:0.82rem;color:rgba(255,255,255,0.55);line-height:1.7;margin-bottom:16px;">Join our team of volunteers and help carry the mission forward — in Canada, Nigeria, and beyond.</p>
          <a href="#contact-form" class="btn-primary" style="display:inline-block;padding:10px 20px;font-size:0.82rem;">Apply to Volunteer →</a>
        </div>
      </div>
      <div class="contact-form fade-up" style="transition-delay:0.14s;" id="contact-form">
        <h3>Send a Message</h3>
        <form action="#" method="POST" novalidate aria-label="Contact form">
          <div class="form-row">
            <div class="form-group">
              <label for="contact-fname">First name</label>
              <input type="text" id="contact-fname" name="first_name" autocomplete="given-name" placeholder="Royal James" required />
            </div>
            <div class="form-group">
              <label for="contact-lname">Last name</label>
              <input type="text" id="contact-lname" name="last_name" autocomplete="family-name" placeholder="Dennis" />
            </div>
          </div>
          <div class="form-group">
            <label for="contact-email">Email address</label>
            <input type="email" id="contact-email" name="email" autocomplete="email" placeholder="you@example.com" required />
          </div>
          <div class="form-group">
            <label for="contact-phone">Phone number (optional)</label>
            <input type="tel" id="contact-phone" name="phone" autocomplete="tel" placeholder="+1 (613) 000-0000" />
          </div>
          <div class="form-group">
            <label for="contact-subject">I'm reaching out about</label>
            <select id="contact-subject" name="subject">
              <option value="">Select a topic…</option>
              <option value="events">Events &amp; Registration</option>
              <option value="volunteer">Volunteering</option>
              <option value="partnership">Partnership / The Bridge</option>
              <option value="counselling">Mental Health Counselling</option>
              <option value="missions">Missions &amp; Outreach</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="contact-message">Message</label>
            <textarea id="contact-message" name="message" placeholder="Tell us how we can help…" required></textarea>
          </div>
          <button type="submit" class="form-submit">Send Message →</button>
        </form>
      </div>
    </div>
  </div>
</section>
